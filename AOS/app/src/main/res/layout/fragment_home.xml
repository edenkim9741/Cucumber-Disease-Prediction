<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 인사 + 우상단 사람 아이콘 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/greetingText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="안녕하세요 농부님!"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <!-- 우상단 사람 아이콘 -->
            <ImageView
                android:id="@+id/profileIcon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/profile_circle_background"
                android:scaleType="centerCrop"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="프로필" />

        </LinearLayout>

        <!-- 요일 캘린더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout android:id="@+id/dayMon"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="월" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="16" android:textSize="14sp" android:textColor="#1A1A1A"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/dayTue"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="화" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="17" android:textSize="14sp" android:textColor="#1A1A1A"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/dayWed"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="수" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="18" android:textSize="14sp" android:textColor="#1A1A1A"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/dayThu"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="목" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="19" android:textSize="14sp" android:textColor="#1A1A1A"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/dayFri"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="금" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="20" android:textSize="14sp" android:textColor="#1A1A1A"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/daySat"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="토" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="21" android:textSize="14sp" android:textColor="#1A1A1A"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/daySun"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="일" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="22" android:textSize="14sp" android:textColor="#1A1A1A"/>
            </LinearLayout>

        </LinearLayout>

        <!-- 오늘의 농사 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="오늘의 농사"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="10dp"/>

        <!-- 날씨 + 알림 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="현재 날씨" android:textSize="12sp" android:textColor="#888888"
                        android:layout_marginBottom="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌧 7°" android:textSize="28sp" android:textStyle="bold"
                        android:textColor="#1A1A1A" android:layout_marginBottom="8dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="강수량" android:textSize="10sp" android:textColor="#AAAAAA"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="1mm" android:textSize="11sp" android:textColor="#555555"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="습도" android:textSize="10sp" android:textColor="#AAAAAA"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="80%" android:textSize="11sp" android:textColor="#555555"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="풍속" android:textSize="10sp" android:textColor="#AAAAAA"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="1%" android:textSize="11sp" android:textColor="#555555"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="알림" android:textSize="12sp" android:textColor="#888888"
                        android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="노균병 발병 주의..." android:textSize="13sp" android:textColor="#1A1A1A"
                        android:layout_marginBottom="12dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="질병 발생" android:textSize="12sp" android:textColor="#888888"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="3건" android:textSize="32sp" android:textStyle="bold"
                        android:textColor="#1A1A1A"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- 할 일 배너 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#D6EDD8">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="노균병 예방 다코닐 살포하기"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="#2D6A2D"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="하우스 환기하고 온습도 조절!!"
                        android:textSize="12sp" android:textColor="#4A8A4A"/>
                </LinearLayout>
                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="✓"
                    android:textSize="20sp"
                    android:textColor="#2D6A2D"
                    android:gravity="center"
                    android:background="@drawable/day_highlight_background"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 오늘의 안전 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="오늘의 안전"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="더보기"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 예취작업은 반드시 오른쪽에서 왼쪽으로 한다.\n• 햄들은 양손으로 잡고 반드시 오른쪽에서 왼쪽방향으로 한다."
                    android:textSize="12sp"
                    android:textColor="#555555"
                    android:lineSpacingMultiplier="1.4"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
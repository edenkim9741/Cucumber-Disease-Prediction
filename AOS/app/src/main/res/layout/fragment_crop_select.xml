<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F4EE"
    android:padding="24dp">

    <!-- 탭 (촬영 / 기록) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tabShoot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="병해진단"
            android:textSize="13sp"
            android:textColor="@color/dark_green"
            android:paddingEnd="16dp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tabHistory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="기록 확인"
            android:textSize="13sp"
            android:textColor="#AAAAAA"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- 타이틀 -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="작물 선택"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/dark_green"
        android:layout_marginBottom="4dp"/>

    <!-- 서브타이틀 -->
    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="병해 진단을 원하는 작물을 선택해주세요."
        android:textSize="13sp"
        android:textColor="#888888"
        android:layout_marginBottom="24dp"/>

    <!-- 작물 그리드 (2열 3행) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- 1행: 오이, 딸기 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/cropCucumber"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/crop_circle_background"
                android:layout_margin="12dp">
                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/crop_circle_background"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="오이"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cropStrawberry"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="12dp">
                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/crop_circle_background"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="딸기"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- 2행: 파프리카, 포도 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/cropPaprika"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="12dp">
                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/crop_circle_background"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="파프리카"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cropGrape"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="12dp">
                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/crop_circle_background"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="포도"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- 3행: 고추, 토마토 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/cropPepper"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="12dp">
                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/crop_circle_background"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="고추"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cropTomato"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="12dp">
                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/crop_circle_background"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="토마토"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- 하단 버튼 -->
    <Button
        android:id="@+id/actionButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="촬영하기"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/primary_green"
        android:stateListAnimator="@null"/>

</LinearLayout>